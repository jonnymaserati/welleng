
{
	"$schema"     : "https://json-schema.org/draft/2020-12/schema",
	"$id"         : "https://github.com/iscwsa/error-models/blob/main/schemas/metadata.json",
	"type"        : "object",
	"title"       : "Metadata",
	"description" : "Information about the model",

	"properties": {

		"schema_uuid"      : {"$ref": "./draft.json#/$defs/schema_uuid"},
		"model_uuid"       : {"$ref": "./strings/non_empty.json"},
		"model_id"         : {"$ref": "./strings/non_empty.json"},
		"short_name"       : {"$ref": "./strings/non_empty.json"},
		"long_name"        : {"$ref": "./strings/non_empty.json"},
		"revision_number"  : {"$ref": "./number/non_negative.json"},
		"revision_date"    : {"$ref": "./strings/date.json"},
		"revision_comment" : {"$ref": "./strings/non_empty.json"},
		"source"           : {"$ref": "./strings/non_empty.json"},
		"application"      : {"$ref": "./strings/non_empty.json"},
		"tool_type"        : {"$ref": "./tool_types.json"},
		"author"           : {"$ref": "./strings/non_empty.json"},
		"framework"        : {"$ref": "./frameworks.json"},
		"tags"             : {"$ref": "./tags.json"}

	},

	"required": [
		"schema_uuid",
		"model_uuid",
		"model_id",
		"short_name",
		"long_name",
		"revision_number",
		"revision_date",
		"revision_comment",
		"source",
		"application",
		"tool_type",
		"author",
		"framework",
		"tags"
	],

	"additionalProperties" : false

}
